 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z\"\n                      />\n                    </svg>\n                    <span>Repository</span>\n                  </a>\n                </div>\n              </div>\n            </article>\n\n            <article class=\"project\">\n              <a\n                href=\"conference.html\"\n                aria-label=\"Open the Inference Conference writeup\"\n              >\n                <img\n                  class=\"project-image\"\n                  src=\"/assets/inference-conference.png\"\n                  alt=\"Animated preview for the inference conference project\"\n                />\n              </a>\n              <div class=\"project-body\">\n                <div class=\"project-kicker\">AI eval case study</div>\n                <h3>Inference Conference</h3>\n                <p>\n                  Three AIs walk into a frontier lab. This is what happened.\n                </p>\n                <div class=\"links\">\n                  <i><a href=\"conference.html\">Writeup</a></i>\n                  <a\n                    class=\"repo-link\"\n                    href=\"https://github.com/rxdt/inference_conference\"\n                    aria-label=\"Inference Conference GitHub repository\"\n                  >\n                    <svg\n                      viewBox=\"0 0 16 16\"\n                      aria-hidden=\"true\"\n                      focusable=\"false\"\n                    >\n                      <path\n                        fill=\"currentColor\"\n                        d=\"M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.67 7.67 0 0 1 8 3.86c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z\"\n                      />\n                    </svg>\n                    <span>Repository</span>\n                  </a>\n                </div>\n              </div>\n            </article>\n          </div>\n        </div>\n      </section>\n\n      <section id=\"focus\">\n        <div class=\"shell\">\n          <div class=\"section-head\">\n            <h2>What I Care About</h2>\n            <p class=\"section-note\">\n              Thoughtful adoption, not hype. Minimalism, not line count.\n              Evidence, not guesses. And moves regardless of the crowd. Curious\n              about: AHI (agent-human-interaction), the evolution of\n              evaluations, and the practical mess of using AI to build.\n            </p>\n          </div>\n          <div class=\"focus-grid\">\n            <div class=\"focus\">\n              <strong>Loops</strong>\n              <span\n                >Everything comes full circle. Fresh context, clear specs,\n                commiting, and quality. In life and in code.</span\n              >\n            </div>\n            <div class=\"focus\">\n              <strong>Evaluation that bites</strong>\n              <span\n                >Measure the path, audit the source, and treat confident\n                wrongness as worse than refusing to guess.</span\n              >\n            </div>\n            <div class=\"focus\">\n              <strong>Practicality</strong>\n              <span\n                >Elegance in less. Clear interfaces. And enough empathy that the\n                next human gets it.</span\n              >\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section id=\"contact\">\n        <div class=\"shell contact\">\n          <div>\n            <h2>Find Me</h2>\n            <p class=\"section